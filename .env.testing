# =============================================================================
# Test Environment
# =============================================================================
# Used by docker-compose.test.yml for isolated, in-memory MariaDB test runs.
# APP_KEY is a static test-only key — never use in production.
# =============================================================================
APP_NAME=Cinemacloud
APP_ENV=testing
APP_KEY=base64:eHh4eHh4eHh4eHh4eHh4eHh4eHh4eHh4eHh4eHh4eHg=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

# =============================================================================
# Logging — warnings only to keep test output clean
# =============================================================================
LOG_CHANNEL=stderr
LOG_LEVEL=warning

# =============================================================================
# Auth
# =============================================================================
AUTH_RATE_LIMIT_MAX_ATTEMPTS=5
AUTH_RATE_LIMIT_DECAY_MINUTES=1

JWT_SECRET=testing-jwt-secret-key-that-is-long-enough-for-hmac
JWT_TTL=60
JWT_REFRESH_TTL=20160
JWT_ALGO=HS256

BCRYPT_ROUNDS=4

# =============================================================================
# Database — separate in-memory MariaDB service (db_test via tmpfs)
# =============================================================================
DB_CONNECTION=mysql
DB_HOST=db_test
DB_PORT=3306
DB_DATABASE=cinemacloud_test
DB_USERNAME=cinemacloud
DB_PASSWORD=secret
DB_ROOT_PASSWORD=root

# =============================================================================
# Redis — reused from the shared service; drivers set to array so no real I/O
# =============================================================================
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# =============================================================================
# Fast in-process drivers — no external dependencies for cache/queue/mail/session
# =============================================================================
CACHE_STORE=array
SESSION_DRIVER=array
QUEUE_CONNECTION=sync
BROADCAST_CONNECTION=log
MAIL_MAILER=array
MAIL_FROM_ADDRESS="hello@cinemacloud.com"
MAIL_FROM_NAME="${APP_NAME}"

# =============================================================================
# Dev tools — all disabled in test
# =============================================================================
TELESCOPE_ENABLED=false

