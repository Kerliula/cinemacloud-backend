# =============================================================================
# Application
# =============================================================================
APP_NAME=Cinemacloud
APP_ENV=local
# Required when SESSION_ENCRYPT=true — run: php artisan key:generate
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Localisation
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Maintenance mode: stores status in /storage/framework/down when enabled
APP_MAINTENANCE_DRIVER=file

# Number of bcrypt rounds for password hashing (higher = slower = more secure)
BCRYPT_ROUNDS=12

# =============================================================================
# Logging
# =============================================================================
# stderr is ideal for Docker — logs are captured by the container runtime
LOG_CHANNEL=stderr
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
# Use 'warning' in production to reduce noise
LOG_LEVEL=debug

# =============================================================================
# Database
# =============================================================================
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=cinemacloud
DB_USERNAME=cinemacloud
DB_PASSWORD=
DB_ROOT_PASSWORD=

# =============================================================================
# Redis
# =============================================================================
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# =============================================================================
# Cache
# =============================================================================
CACHE_STORE=redis

# =============================================================================
# Session
# =============================================================================
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
# Set to your domain in production, e.g., .cinemacloud.com
SESSION_DOMAIN=null

# =============================================================================
# Queue
# =============================================================================
QUEUE_CONNECTION=redis

# =============================================================================
# Broadcasting
# =============================================================================
# Use 'redis' in production for real-time features
BROADCAST_CONNECTION=log

# =============================================================================
# Storage
# =============================================================================
# Use 's3' in production for persistent file storage
FILESYSTEM_DISK=local

# =============================================================================
# Mail
# =============================================================================
MAIL_MAILER=smtp
MAIL_SCHEME=null
# Mailpit catches all emails locally — visit http://localhost:8025 to view them
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="hello@cinemacloud.com"
MAIL_FROM_NAME="${APP_NAME}"

# =============================================================================
# Telescope (dev only, excluded from production image via --no-dev)
# =============================================================================
TELESCOPE_ENABLED=true

# =============================================================================
# JWT
# =============================================================================
JWT_SECRET=
JWT_TTL=60 # 1 hour in minutes
JWT_REFRESH_TTL=20160 # 2 weeks in minutes
JWT_ALGO=HS256