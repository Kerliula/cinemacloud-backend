# =============================================================================
# Docker Image Versions
# =============================================================================
# Pin these to specific versions for reproducibility.
# Before upgrading, verify compatibility at https://hub.docker.com
# and check Laravel 12 requirements at https://laravel.com/docs/12.x/deployment
# If changing PHP version, also update the GitHub Actions workflow in .github/workflows/tests.yml
# =============================================================================
PHP_VERSION=8.5
NGINX_VERSION=1.29
REDIS_VERSION=8.6
MARIADB_VERSION=12
MAILPIT_VERSION=v1.22

# =============================================================================
# Application
# =============================================================================
# Debug mode should be 'true' for local development, switch to 'false' in production
# Maintenance mode: stores status in /storage/framework/down when enabled
# =============================================================================
APP_NAME=Cinemacloud
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

# =============================================================================
# Logging
# =============================================================================
# stderr is ideal for Docker — logs are captured by the container runtime
# Use 'warning' in production to reduce noise
# =============================================================================
LOG_CHANNEL=stderr
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# =============================================================================
# Auth
# =============================================================================
# Limit login attempts to prevent brute-force attacks, adjust as needed
# Number of bcrypt rounds for password hashing (higher = slower = more secure)
# =============================================================================
AUTH_RATE_LIMIT_MAX_ATTEMPTS=5
AUTH_RATE_LIMIT_DECAY_MINUTES=1

JWT_SECRET=
JWT_TTL=60
JWT_REFRESH_TTL=20160
JWT_ALGO=HS256

BCRYPT_ROUNDS=12

# =============================================================================
# Web Server
# =============================================================================
NGINX_PORT=8080

# =============================================================================
# Database
# =============================================================================
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=cinemacloud
DB_USERNAME=cinemacloud
DB_PASSWORD=root
DB_ROOT_PASSWORD=root

# =============================================================================
# Redis
# =============================================================================
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# =============================================================================
# Cache
# =============================================================================
# Use 'redis' for better performance in production, 'file' is fine for local development
# =============================================================================
CACHE_STORE=redis

# =============================================================================
# Session
# =============================================================================
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
# Set to your domain in production, e.g., .cinemacloud.com
SESSION_DOMAIN=null

# =============================================================================
# Queue
# =============================================================================
QUEUE_CONNECTION=redis

# =============================================================================
# Broadcasting
# =============================================================================
# Use 'log' for development, switch to 'pusher' or 'redis' in production for real-time features
# =============================================================================
BROADCAST_CONNECTION=log

# =============================================================================
# Storage
# =============================================================================
FILESYSTEM_DISK=local

# =============================================================================
# Mail
# =============================================================================
# Use 'smtp' with Mailpit in development, switch to 'ses' or 'smtp' with real provider in production
# =============================================================================
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="hello@cinemacloud.com"
MAIL_FROM_NAME="${APP_NAME}"

MAILPIT_WEB_PORT=8025

# =============================================================================
# DEV Tools (dev only, excluded from production image via --no-dev)
# =============================================================================
TELESCOPE_ENABLED=true
INSTALL_XDEBUG=true